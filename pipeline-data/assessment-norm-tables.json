  "percentile_to_stage_guidance": {
    "description": "百分位数与阶位的参照对应关系",
    "mapping": [
      {"percentile_range": [0, 10],    "stage_reference": "不会~模糊",   "interpretation": "需要基础知识重建"},
      {"percentile_range": [10, 30],   "stage_reference": "模糊~清晰",   "interpretation": "知识点存在但结构不清晰"},
      {"percentile_range": [30, 60],   "stage_reference": "清晰~框架",   "interpretation": "知识理解达到平均水平"},
      {"percentile_range": [60, 80],   "stage_reference": "框架~运用",   "interpretation": "具备较好的知识框架"},
      {"percentile_range": [80, 95],   "stage_reference": "运用~熟练",   "interpretation": "超越大多数同龄学生"},
      {"percentile_range": [95, 100],  "stage_reference": "熟练~创新",   "interpretation": "优秀水平，接近创新阶位"}
    ]
  },
  "norm_update_policy": {
    "update_frequency": "quarterly",
    "min_sample_size_per_group": 200,
    "rolling_window_months": 12,
    "normalization_method": "z_score_then_theta_scale"
  },
  "validation_rules": {
    "percentile_keys": ["p10", "p20", "p30", "p40", "p50", "p60", "p70", "p80", "p90", "p95", "p99"],
    "percentile_monotonicity": "p10 < p20 < ... < p99",
    "stage_distribution_sum": "sum(stage_distribution.values()) == 1.0",
    "stage_names_enum": ["不会", "模糊", "清晰", "框架", "运用", "熟练", "创新"],
    "mece_norm_keys": ["M_mean", "M_sd", "E_exec_mean", "E_exec_sd", "C_theta_mean", "C_theta_sd", "E_env_mean", "E_env_sd"],
    "pipl_constraints": "常模数据为群体统计; 不含个体 student_id 或真实姓名"
  }
