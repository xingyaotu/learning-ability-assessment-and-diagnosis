      "tool_name_zh": "学习动力测评",
      "cat_enabled": true,
      "item_selection": {
        "method": "maximum_information",
        "fallback": "closest_difficulty",
        "content_balancing": true,
        "content_constraint": "each dimension ≥ 1 item"
      },
      "stopping_rules": {
        "max_items": 16,
        "min_items": 8,
        "se_threshold": 0.35,
        "rule": "stop if SE ≤ se_threshold OR items_administered ≥ max_items"
      },
      "exposure_control": {
        "method": "Sympson-Hetter",
