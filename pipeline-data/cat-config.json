{
  "$schema": "https://xingyaotu.cn/schemas/cat-config.v1.0.json",
  "version": "1.0",
  "compliance": "v5.6 道层零漂移",
  "last_updated": "2026-05-21",
  "_meta": {
    "description": "自适应测评(CAT) 配置 — 控制 IRT 自适应选题、停止规则与曝光控制",
    "cat_method": "Maximum Information / Closest Difficulty Hybrid",
    "usage": "assessment pipeline → cat-config → 动态选题 → IRT 能力估计 → irt-scoring-thresholds → 七阶分类"
  },
  "global_cat_settings": {
    "ability_estimation_method": "EAP",
    "prior_distribution": {"mean": 0.0, "sd": 1.0, "type": "normal"},
    "initial_theta": 0.0,
    "se_scale": "IRT information function",
    "theta_range": [-4.0, 4.0]
  },
